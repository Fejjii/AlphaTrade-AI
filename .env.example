# ---------------------------------------------------------------------------
# AlphaTrade AI - example environment configuration
# Copy to `.env` and adjust. SAFE DEFAULTS: paper mode, real trading disabled.
# See also: `.env.docker.example`, `.env.staging.example`
# ---------------------------------------------------------------------------

# --- Application ---
APP_NAME="AlphaTrade AI"
ENVIRONMENT=local            # local | staging | production
DEBUG=true
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
LOG_JSON=false               # JSON logs (true) or console-friendly (false)

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated list of allowed CORS origins.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Trading safety (DO NOT enable real trading in this scaffold) ---
# execution_mode: paper | read_only | trade
EXECUTION_MODE=paper
# Hard kill switch for any real exchange execution. Must be true AND
# EXECUTION_MODE=trade for live orders. Keep false.
ENABLE_REAL_TRADING=false

# --- Exchange connectivity (Slice 56A — demo only; independent of EXECUTION_MODE) ---
# exchange_mode: paper_internal | paper_exchange_demo | trade_live
#   paper_internal      — pure in-database simulation (default, no exchange calls)
#   paper_exchange_demo — route paper orders to a BloFin DEMO account (not real money)
#   trade_live          — PERMANENTLY BLOCKED; selecting it refuses startup
EXCHANGE_MODE=paper_internal
BLOFIN_DEMO_ENABLED=false
# Env-only credentials for a single shared BloFin demo account. Leave blank unless
# EXCHANGE_MODE=paper_exchange_demo. Never commit real values.
BLOFIN_API_KEY=
BLOFIN_API_SECRET=
BLOFIN_API_PASSPHRASE=
# Must be an allowlisted BloFin demo host over HTTPS/WSS (production hosts rejected).
BLOFIN_DEMO_REST_BASE_URL=
BLOFIN_DEMO_WS_URL=
BLOFIN_REQUEST_TIMEOUT_SECONDS=10
BLOFIN_MAX_RETRIES=2
BLOFIN_RATE_LIMIT_REQUESTS_PER_SECOND=5

# --- Data stores ---
# Local development (services on localhost):
DATABASE_URL=postgresql+psycopg://alphatrade:alphatrade@localhost:5432/alphatrade
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333

# Docker Compose (uncomment when running `docker compose up`):
# DATABASE_URL=postgresql+psycopg://alphatrade:alphatrade@postgres:5432/alphatrade
# REDIS_URL=redis://redis:6379/0
# QDRANT_URL=http://qdrant:6333

# --- Providers (leave credentials blank for mock/fallback mode) ---
# provider_mode:
#   mock     — deterministic mocks only (default, safe for tests)
#   fallback — try OpenAI/Qdrant when configured; fall back to mocks if unavailable
#   live     — same as fallback (real trading still disabled)
PROVIDER_MODE=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
EMBEDDINGS_MODEL=text-embedding-3-small
# Optional. Auto: 384 (mock) or model native size when OPENAI_API_KEY is set
# (1536 for text-embedding-3-small). Set explicitly after switching providers.
# EMBEDDINGS_DIMENSIONS=1536
# Qdrant Cloud / authenticated deployments:
# QDRANT_API_KEY=

# --- Background worker (Slice 59 — disabled by default; never trades) ---
WORKER_ENABLED=false
# process = dedicated worker service; in_process = daemon thread inside the API
WORKER_MODE=process
WORKER_NAME=alphatrade-worker
WORKER_SCAN_INTERVAL_SECONDS=60
WORKER_LOCK_TTL_SECONDS=120
WORKER_HEARTBEAT_INTERVAL_SECONDS=30
# Worker system alerts (Slice 60 — outbound only; Telegram can never trade).
# Requires ALERT_DELIVERY_ENABLED=true and TELEGRAM_ALERTS_ENABLED=true to send.
WORKER_ALERTS_ENABLED=false
WORKER_ALERT_MIN_SEVERITY=info        # info | warning | critical
WORKER_QUIET_HOURS_START=             # "HH:MM" UTC; empty disables quiet hours
WORKER_QUIET_HOURS_END=

# --- Market data (read-only) ---
MARKET_DATA_ENABLED=true
MARKET_DATA_PROVIDER=binance
MARKET_DATA_CACHE_USE_REDIS=true

# --- Observability (optional) ---
OBSERVABILITY_STRICT_MODE=false
LANGSMITH_API_KEY=

# --- Authentication ---
JWT_SECRET=change-me-in-production-use-long-random-value
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
# Bearer mode (local dev default):
AUTH_REFRESH_COOKIE_ENABLED=false
AUTH_OMIT_REFRESH_FROM_BODY=true
# Cookie mode (Docker / staging / production — see .env.staging.example):
# AUTH_REFRESH_COOKIE_ENABLED=true
# AUTH_COOKIE_SECURE=false          # true in staging/production (HTTPS)
# AUTH_COOKIE_SAMESITE=lax          # none for cross-domain Vercel + API
# ACCESS_TOKEN_DENYLIST_ENABLED=true
# ACCESS_TOKEN_DENYLIST_USE_REDIS=true

# --- Email (Slice 25 — mock default) ---
EMAIL_PROVIDER=mock
EMAIL_FROM_ADDRESS=noreply@alphatrade.local
EMAIL_BASE_URL=http://localhost:3000
EMAIL_SEND_ENABLED=true
# REQUIRE_EMAIL_VERIFIED=          # unset: local=false, staging/production=true
# EMAIL_AUTO_VERIFY_LOCAL=false

# --- Billing (Slice 26 — disabled by default) ---
BILLING_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
BILLING_CHECKOUT_SUCCESS_URL=http://localhost:3000/billing?checkout=success
BILLING_CHECKOUT_CANCEL_URL=http://localhost:3000/billing?checkout=cancel
BILLING_PORTAL_RETURN_URL=http://localhost:3000/billing

# --- Rate limiting ---
RATE_LIMIT_USE_REDIS=true
RATE_LIMIT_ALLOW_IN_MEMORY_FALLBACK=true
