# ---------------------------------------------------------------------------
# AlphaTrade AI — Docker Compose local stack template
# Copy to `.env` when overriding Compose defaults (optional).
# Safe defaults are already set in docker-compose.yml.
# ---------------------------------------------------------------------------

# --- Application ---
ENVIRONMENT=local
DEBUG=false
LOG_LEVEL=INFO
LOG_JSON=true

# --- API ---
API_PORT=8000
FRONTEND_PORT=3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Trading safety ---
EXECUTION_MODE=paper
ENABLE_REAL_TRADING=false

# --- Providers ---
PROVIDER_MODE=mock
OPENAI_API_KEY=

# --- Authentication (cookie mode for Compose demos) ---
JWT_SECRET=change-me-in-production-use-long-random-value
AUTH_REFRESH_COOKIE_ENABLED=true
AUTH_OMIT_REFRESH_FROM_BODY=true
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
ACCESS_TOKEN_DENYLIST_ENABLED=true
ACCESS_TOKEN_DENYLIST_USE_REDIS=true

# --- Rate limiting ---
RATE_LIMIT_USE_REDIS=true
RATE_LIMIT_ALLOW_IN_MEMORY_FALLBACK=true

# Compose sets DATABASE_URL, REDIS_URL, QDRANT_URL to service hostnames internally.
