# ---------------------------------------------------------------------------
# AlphaTrade AI — staging environment template
# Copy to platform secret store / Render / Railway env. DO NOT commit secrets.
# ---------------------------------------------------------------------------

# --- Application ---
APP_NAME="AlphaTrade AI"
ENVIRONMENT=staging
DEBUG=false
LOG_LEVEL=INFO
LOG_JSON=true

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated deployed frontend origin(s) — must match Vercel URL exactly.
# Production alias (Slice 48): https://alpha-trade-ai-eight.vercel.app
# Do NOT use https://alphatrade-ai.vercel.app (unrelated legacy app).
CORS_ORIGINS=https://alpha-trade-ai-eight.vercel.app,https://alpha-trade-ai-alphatrade-ai.vercel.app

# --- Trading safety (required — keep paper-only) ---
EXECUTION_MODE=paper
ENABLE_REAL_TRADING=false

# --- Exchange connectivity (Slice 56A — demo only; staging may use BloFin demo) ---
# paper_internal (default) or paper_exchange_demo. trade_live is never allowed.
# paper_exchange_demo is permitted on staging only, never production.
EXCHANGE_MODE=paper_internal
BLOFIN_DEMO_ENABLED=false
# Demo-only keys (read + trade scope). Withdraw/transfer scope is refused at startup.
# Never use production BloFin hosts — only the allowlisted demo host below.
BLOFIN_API_KEY=
BLOFIN_API_SECRET=
BLOFIN_API_PASSPHRASE=
# Official BloFin demo REST base URL (HTTPS only; production hosts blocked):
BLOFIN_DEMO_REST_BASE_URL=https://demo-trading-openapi.blofin.com
# Optional demo WebSocket URLs (WSS only):
# BLOFIN_DEMO_WS_URL=wss://demo-trading-openapi.blofin.com/ws/public
# Private channel (if needed): wss://demo-trading-openapi.blofin.com/ws/private
BLOFIN_DEMO_WS_URL=

# --- Managed data stores (replace with your provider URLs) ---
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/alphatrade
# Use Upstash/Render Redis with TLS: rediss://:PASSWORD@HOST:6379/0
# If invalid/unavailable, set RATE_LIMIT_ALLOW_IN_MEMORY_FALLBACK=true (staging only).
REDIS_URL=rediss://:PASSWORD@HOST:6379/0
# Optional: leave empty for in-memory RAG fallback on staging (production requires hosted Qdrant).
QDRANT_URL=
# Required for Qdrant Cloud / authenticated clusters (never commit real values).
QDRANT_API_KEY=

# --- Providers ---
PROVIDER_MODE=fallback
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
EMBEDDINGS_MODEL=text-embedding-3-small
# Auto when unset: 1536 with OpenAI key + text-embedding-3-small; 384 for mock.
# After enabling OpenAI on a cluster that already has mock 384-d vectors, recreate
# alphatrade_knowledge (see docs/rag_system.md) then reingest.
# EMBEDDINGS_DIMENSIONS=1536

# --- Market data (read-only) ---
MARKET_DATA_ENABLED=true
MARKET_DATA_PROVIDER=binance
MARKET_DATA_CACHE_USE_REDIS=true

# --- Observability ---
OBSERVABILITY_STRICT_MODE=false
# AT-016: keep disabled unless scrape token is set in the secret store
METRICS_ENABLED=false
METRICS_SCRAPE_TOKEN=
LANGSMITH_API_KEY=

# --- Authentication (HTTPS cookie mode — required for staging) ---
JWT_SECRET=REPLACE_WITH_32_PLUS_BYTE_RANDOM_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_REFRESH_COOKIE_ENABLED=true
AUTH_OMIT_REFRESH_FROM_BODY=true
AUTH_COOKIE_SECURE=true
# Use `none` when frontend and API are on different domains (Vercel + Render).
AUTH_COOKIE_SAMESITE=none
ACCESS_TOKEN_DENYLIST_ENABLED=true
ACCESS_TOKEN_DENYLIST_USE_REDIS=true

# --- Rate limiting (Redis required in staging) ---
RATE_LIMIT_USE_REDIS=true
RATE_LIMIT_ALLOW_IN_MEMORY_FALLBACK=true

# --- Billing (scaffold only — keep disabled until explicitly approved) ---
BILLING_ENABLED=false

# --- Alert delivery & notifications (Slice 46 — keep disabled on staging) ---
ALERT_DELIVERY_ENABLED=false
ALERT_WEBHOOK_ENABLED=false
TELEGRAM_ALERTS_ENABLED=false
EMAIL_PROVIDER=mock

# --- Market watcher (read-only; manual scan only unless explicitly enabled) ---
MARKET_WATCHER_ENABLED=false
MARKET_WATCHER_BRIDGE_ENABLED=false

# --- Email verification (staging defaults require verified login) ---
# unset → true in staging/production, false in local
# REQUIRE_EMAIL_VERIFIED=false   # optional: allow unverified login on staging demo only
DEMO_SEED_ENABLED=true           # enable POST /demo/seed on staging (owner-only)
# EMAIL_AUTO_VERIFY_LOCAL=true   # local only; auto-verify on register when ENVIRONMENT=local
