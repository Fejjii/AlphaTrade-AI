# ---------------------------------------------------------------------------
# AlphaTrade AI — production environment template
# Copy values to platform secret store. DO NOT commit filled files.
# ---------------------------------------------------------------------------

# --- Application ---
APP_NAME="AlphaTrade AI"
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
LOG_JSON=true

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=https://app.yourdomain.com

# --- Trading safety (required — paper-only until explicit live-trading slice) ---
EXECUTION_MODE=paper
ENABLE_REAL_TRADING=false

# --- Managed data stores ---
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/alphatrade
REDIS_URL=redis://:PASSWORD@HOST:6379/0
QDRANT_URL=https://YOUR-CLUSTER.qdrant.io

# --- Providers ---
PROVIDER_MODE=fallback
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
EMBEDDINGS_MODEL=text-embedding-3-small

# --- Market data (read-only) ---
MARKET_DATA_ENABLED=true
MARKET_DATA_PROVIDER=binance
MARKET_DATA_CACHE_USE_REDIS=true

# --- Observability ---
OBSERVABILITY_STRICT_MODE=true
LANGSMITH_API_KEY=

# --- Authentication (HTTPS cookie mode — required) ---
JWT_SECRET=REPLACE_WITH_32_PLUS_BYTE_RANDOM_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_REFRESH_COOKIE_ENABLED=true
AUTH_OMIT_REFRESH_FROM_BODY=true
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=none
ACCESS_TOKEN_DENYLIST_ENABLED=true
ACCESS_TOKEN_DENYLIST_USE_REDIS=true

# --- Rate limiting ---
RATE_LIMIT_USE_REDIS=true
RATE_LIMIT_ALLOW_IN_MEMORY_FALLBACK=false
