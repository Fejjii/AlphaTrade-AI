# Frontend environment (copy to `.env.local` for local dev)
# See also: `.env.staging.example` for Vercel / staging deployment.

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=AlphaTrade AI
NEXT_PUBLIC_EXECUTION_MODE=paper
NEXT_PUBLIC_PROVIDER_MODE=mock

# Bearer mode (local dev default). Set true for Docker Compose or staging:
# NEXT_PUBLIC_AUTH_COOKIE_MODE=true
